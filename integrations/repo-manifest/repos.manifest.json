{
    "manifestVersion": "1.1",
    "project": "remote-business-partner",
    "description": "Corrected repository manifest for Firebase Studio and related application workspaces. This file references external and supporting repositories without storing all source code in the main workspace repo.",
    "authoritativeRuntime": {
      "activeBenchPath": "rbp-bench/rbp-bench",
      "activeSite": "rbp.local",
      "note": "Treat the inner bench as the authoritative development runtime."
    },
    "recommendedUsage": {
      "defaultMode": "reference",
      "submoduleCandidates": [
        "rbp_core"
      ],
      "doNotVendAllSourcesIntoMainRepo": true
    },
    "repositories": [
      {
        "name": "Dolibarr",
        "key": "dolibarr",
        "url": "https://github.com/info-rbp/rpb-dolibarr-repository",
        "type": "reference",
        "purpose": "ERP/operations capability reference",
        "notes": "External application reference for business operations capability."
      },
      {
        "name": "Frappe",
        "key": "frappe",
        "url": "",
        "type": "available-in-bench",
        "purpose": "Core framework and active platform foundation",
        "notes": "Already available in the active bench/runtime. No external link required in the manifest."
      },
      {
        "name": "Metabase",
        "key": "metabase",
        "url": "https://github.com/info-rbp/rpb-metabase",
        "type": "reference",
        "purpose": "Analytics and BI capability",
